{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Rose Pine Custom",
  "author": "Makakashan",
  "themes": [
    {
      "name": "Rose Pine Custom",
      "appearance": "dark",
      "style": {
        "background.appearance": "transparent",
        "background": "#04040480",
        "surface.background": "transparent",
        "elevated_surface.background": "#1f1d2e",

        "editor.background": "#04040480",
        "editor.gutter.background": "#04040480",
        "editor.foreground": "#e0def4",
        "editor.line_number": "#6e6a86",
        "editor.active_line_number": "#e0def4",
        "editor.active_line.background": "#1f1d2e80",
        "editor.document_highlight.write_background": "#bbbbbb77",

        "element.background": "#04040400",
        "element.hover": "#adadad33",
        "element.active": "#adadad44",
        "element.selected": "#adadad33",

        "border": "#26233a",
        "border.variant": "#26233a80",
        "border.focused": "#26234a",
        "border.selected": "#26234a",

        "players": [
          {
            "cursor": "#403d52",
            "background": "#403d52",
            "selection": "#403d5260"
          },
          {
            "cursor": "#adadad",
            "background": "#adadad",
            "selection": "#adadad3d"
          },
          {
            "cursor": "#adadad",
            "background": "#adadad",
            "selection": "#adadad3d"
          },
          {
            "cursor": "#bbbbbb",
            "background": "#bbbbbb",
            "selection": "#bbbbbb3d"
          },
          {
            "cursor": "#dcdcdc",
            "background": "#dcdcdc",
            "selection": "#dcdcdc3d"
          },
          {
            "cursor": "#dcdcdc",
            "background": "#dcdcdc",
            "selection": "#dcdcdc3d"
          },
          {
            "cursor": "#eaebef",
            "background": "#eaebef",
            "selection": "#eaebef3d"
          },
          {
            "cursor": "#adadad",
            "background": "#adadad",
            "selection": "#adadad3d"
          }
        ],

        "text": "#e0def4",
        "text.muted": "#6e6a86",

        "panel.background": "#04040480",

        "status_bar.background": "#04040480",
        "title_bar.background": "#04040480",
        "toolbar.background": "#04040480",
        "tab_bar.background": "#04040480",
        "tab.inactive_background": "#04040480",
        "tab.active_background": "#04040480",

        "scrollbar.thumb.background": "#26233a",
        "scrollbar.track.background": "transparent",

        "terminal.background": "#04040480",
        "terminal.foreground": "#e0def480",
        "terminal.ansi.black": "#26233a",
        "terminal.ansi.red": "#eb6f92",
        "terminal.ansi.green": "#9ccfd8",
        "terminal.ansi.yellow": "#f6c177",
        "terminal.ansi.blue": "#31748f",
        "terminal.ansi.magenta": "#c4a7e7",
        "terminal.ansi.cyan": "#ebbcba",
        "terminal.ansi.white": "#e0def4",
        "terminal.ansi.bright_black": "#6e6a86",
        "terminal.ansi.bright_red": "#eb6f92",
        "terminal.ansi.bright_green": "#9ccfd8",
        "terminal.ansi.bright_yellow": "#f6c177",
        "terminal.ansi.bright_blue": "#31748f",
        "terminal.ansi.bright_magenta": "#c4a7e7",
        "terminal.ansi.bright_cyan": "#ebbcba",
        "terminal.ansi.bright_white": "#e0def4",

        "error": "#eb6f90",
        "error.background": "#99485e",
        "warning": "#ea9d34",
        "warning.background": "#6f4c11",
        "info": "#00aaff90",
        "info.background": "#006699",
        "hint": "#908caa90",
        "hint.background": "#494756",

        "syntax": {
          "comment": { "color": "#6e6a86", "font_style": "italic" },
          "keyword": { "color": "#eb6f92" },
          "function": { "color": "#ebbcba" },
          "string": { "color": "#c4a7e7" },
          "type": { "color": "#9ccfd8" },
          "variable": { "color": "#e0def4" },
          "constant": { "color": "#9ccfd8" },
          "property": { "color": "#e0def4" },
          "punctuation": { "color": "#908caa" },
          "operator": { "color": "#908caa" },
          "number": { "color": "#9ccfd8" },
          "boolean": { "color": "#ebbcba" }
        }
      }
    }
  ]
}
