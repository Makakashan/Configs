{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Rose Pine Custom",
  "author": "Rose Pine & You",
  "themes": [
    {
      "name": "Rose Pine Custom",
      "appearance": "dark",
      "style": {
        "background": "#191724",
        "foreground": "#e0def4",
        "border": "#26233a",
        "border.variant": "#26233a",
        "shadow": "#000000",

        "elevation": {
          "0": { "background": "#191724" },
          "1": { "background": "#1f1d2e", "border": "#26233a" },
          "2": { "background": "#1f1d2e", "border": "#403d52" },
          "3": { "background": "#26233a", "border": "#524f67" },
        },

        "toolbar": { "background": "#191724" },
        "tab_bar": { "background": "#191724", "active_background": "#1f1d2e" },
        "status_bar": { "background": "#191724", "border": "#26233a" },
        "title_bar": { "background": "#191724" },
        "panel": { "background": "#191724", "border": "#26233a" },

        "element": {
          "active": "#26233a",
          "selected": "#26233a",
          "hover": "#1f1d2e",
        },

        "popover": {
          "background": "#1f1d2e",
          "border": "#26233a",
          "foreground": "#e0def4",
        },
        "tooltip": {
          "background": "#1f1d2e",
          "border": "#26233a",
          "foreground": "#e0def4",
        },

        "editor": {
          "background": "#191724",
          "foreground": "#e0def4",
          "line_number": "#6e6a86",
          "active_line_number": "#e0def4",
          "active_line_background": "#1f1d2e",
          "selection": "#26233a",
          "hover_popover": {
            "background": "#1f1d2e",
            "border": "#26233a",
            "foreground": "#e0def4",
          },
        },

        "scrollbar": {
          "track.background": "#191724",
          "thumb.background": "#26233a",
          "thumb.border": "#191724",
        },

        "terminal": {
          "background": "#191724",
          "foreground": "#e0def4",
          "black": "#26233a",
          "red": "#eb6f92",
          "green": "#9ccfd8",
          "yellow": "#f6c177",
          "blue": "#31748f",
          "magenta": "#c4a7e7",
          "cyan": "#ebbcba",
          "white": "#e0def4",
          "bright_black": "#6e6a86",
          "bright_red": "#eb6f92",
          "bright_green": "#9ccfd8",
          "bright_yellow": "#f6c177",
          "bright_blue": "#31748f",
          "bright_magenta": "#c4a7e7",
          "bright_cyan": "#ebbcba",
          "bright_white": "#e0def4",
        },

        "error": "#eb6f92",
        "error.background": "#eb6f9222",
        "error.border": "#eb7f9244",

        "warning": "#ea9d34",
        "warning.background": "#ea9d3422",
        "warning.border": "#ea9d3444",

        "info": "#9ccfd8",
        "info.background": "#9ccfd822",
        "info.border": "#9ccfd844",

        "hint": "#908caa",
        "hint.background": "#908caa22",
        "hint.border": "#908caa44",

        "syntax": {
          "keyword": { "color": "#eb6f92" },
          "keyword.control": { "color": "#eb6f92" },
          "string": { "color": "#c4a7e7" },
          "string.escape": { "color": "#c4a7e7" },
          "function": { "color": "#ebbcba" },
          "function.call": { "color": "#ebbcba" },
          "type": { "color": "#9ccfd8" },
          "variable": { "color": "#e0def4" },
          "constant": { "color": "#9ccfd8" },
          "comment": { "color": "#6e6a86" },
          "punctuation": { "color": "#908caa" },
          "delimiter": { "color": "#908caa" },
          "property": { "color": "#e0def4" },
        },
      },
    },
  ],
}
