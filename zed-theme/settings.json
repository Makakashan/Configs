{
  "format_on_save": "on",
  "session": {
    "trust_all_worktrees": true,
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.3-codex",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "theme": "Rose Pine Custom",
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_size": 16,
  "ui_font_size": 16,
  "languages": {
    "CSS": {
      "language_servers": ["tailwindcss-language-server"],
    },
    "TypeScript": {
      "tab_size": 3,
      "hard_tabs": true,
    },
    "TSX": {
      "tab_size": 3,
      "hard_tabs": true,
    },
  },
  "lsp": {
    "jdtls": {
      "settings": {
        "java_home": "/usr/lib/jvm/java-25-openjdk",
        "lombok_support": true,
      },
    },
  },
}
